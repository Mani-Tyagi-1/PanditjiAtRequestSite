{
  "compilerOptions": {
    "target": "ES2021",
    "module": "node16",

    "lib": ["ES2021", "DOM"],          // <-- gives types for fetch/Request/Response
    "moduleResolution": "node16",        // <-- modern Node resolution
    "types": ["node"],                 // <-- Node globals (process, Buffer, etc.)

    "resolveJsonModule": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true
  }
}
